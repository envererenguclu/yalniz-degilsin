<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title>Farkındalık Sertifikası</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="certificate-page">

  <main class="certificate-wrap">
   <section class="certificate-card certificate-new">

  <div class="cert-left">
    <div class="cert-medal">✦</div>
    <div class="cert-seal-text">YALNIZ<br>DEĞİLSİN</div>
    <div class="cert-line"></div>
    <p>Farkındalık Yolculuğu</p>
  </div>

  <div class="cert-right">

    <div class="cert-top-label">Ruh Sağlığı Farkındalık Belgesi</div>

    <h1>Başarı Sertifikası</h1>

    <p class="cert-presented">Bu sertifika</p>

    <h2><%= ad %></h2>

    <p class="cert-desc">
      adlı katılımcının Yalnız Değilsin platformunda farkındalık yolculuğunu
      tamamladığını ve kendine destek olma sürecine katkı sağladığını gösterir.
    </p>

    <% 
      let sonucYazi = sonuc;
      if (sonuc === "hafif") sonucYazi = "Hafif Farkındalık";
      if (sonuc === "orta") sonucYazi = "Orta Düzey Destek";
      if (sonuc === "yuksek") sonucYazi = "Yüksek Destek İhtiyacı";
    %>

    <div class="cert-info-row">
      <div>
        <span>Sonuç</span>
        <strong><%= sonucYazi %></strong>
      </div>

      <div>
        <span>Puan</span>
        <strong><%= puan %> / <%= maxPuan %></strong>
      </div>

      <div>
        <span>Tarih</span>
        <strong><%= tarih %></strong>
      </div>
    </div>

    <div class="cert-footer">
      <div class="cert-sign">
        <div></div>
        <span>Yalnız Değilsin Ekibi</span>
      </div>

      <p>
        Bu belge tıbbi tanı niteliği taşımaz. Farkındalık ve bilgilendirme amacıyla oluşturulmuştur.
      </p>
    </div>

    <button onclick="window.print()" class="print-btn">
      Sertifikayı Yazdır / PDF Kaydet
    </button>

  </div>

</section>
  </main>

</body>
</html>